var url = "../onlinequiz2/ajax_loader.php";
var urlQ = "../onlinequiz2/question_loader.php";
var imageHtml = "<img src='../media/js/load-animation/throbber.gif'>";

$(document).ready(function() {
    firstOrPageRefresh();
    $("#previous").click(function() {
        disableAllButtons();
        getPrevious();
    });
    $("#skip").click(function() {
        disableAllButtons();
        skipQuestion();
    });
    $("#next").click(function() {
        disableAllButtons();
        saveAnswerGetNext();
    });
    $("body").delegate("li", "mouseover", function(event) {});
});

function getPrevious() {

    var numberOfQuestions = $("#number-of-questions").val();
    var quizId = $("#quiz-id").val();
    var displayedQuestionId = $("#displayed-question-id").val();
    $("#online-quiz-question-error-messages").html("");
    $.post(urlQ, {
	"number-of-questions":numberOfQuestions,
        "quiz-id": quizId,
        "displayed-question-id": displayedQuestionId,
        "prev-question": ""
    }, function(data) {
        finishExam(data.state);
        $("#displayed-question-id").attr("value", data.displayed_question);
        $("#online-quiz-question-area").html(data.html);
        var result = document.getElementById("online-quiz-question-area");
        MathJax.Hub.Queue(["Typeset", MathJax.Hub, result]);
    }, "json");
}

function saveAnswerGetNext() 
{
    var numberOfQuestions = $("#number-of-questions").val();
    var quizId = $("#quiz-id").val();
    var displayedQuestionId = $("#displayed-question-id").val();
    var userId = $("#user-id").val();
    var answer = getAnswers();
    if (answer.length > 0) {
        $("#online-quiz-question-error-messages").html("");
        $.post(urlQ, {
	    "number-of-questions":numberOfQuestions,
            "quiz-id": quizId,
            "answer": answer,
            "displayed-question-id": displayedQuestionId,
            "next-question": ""
        }, function(data) {
            finishExam(data.state);
//		alert("heeellppp");	
            $("#displayed-question-id").attr("value", data.displayed_question);
            $("#online-quiz-question-area").html(data.html);
            if (userId == "11111") {
                $("#online-quiz-question-ids-area").html("[ query time : " + data.msc + "  |  total run : " + data.msc_total + " ]");
            }
            var result = document.getElementById("online-quiz-question-area");
            MathJax.Hub.Queue(["Typeset", MathJax.Hub, result]);
        }, "json");
    } else {
        printError();
    }
}

function skipQuestion() 
{
    var numberOfQuestions = $("#number-of-questions").val();
    var quizId = $("#quiz-id").val();
    var displayedQuestionId = $("#displayed-question-id").val();
    $("#online-quiz-question-error-messages").html("");
    $.post(urlQ, {
	"number-of-questions":numberOfQuestions,        
	"quiz-id": quizId,
        "displayed-question-id": displayedQuestionId,
        "skip-question": ""
    }, function(data) {
        finishExam(data.state);
        $("#displayed-question-id").attr("value", data.displayed_question);
        $("#online-quiz-question-area").html(data.html);
        var result = document.getElementById("online-quiz-question-area");
        MathJax.Hub.Queue(["Typeset", MathJax.Hub, result]);
    }, "json");
}

function firstOrPageRefresh() 
{
    var numberOfQuestions = $("#number-of-questions").val();
    var quizId = $("#quiz-id").val();
    $.post(urlQ, {
	"number-of-questions":numberOfQuestions,        
	"first-or-page-refresh": "",
        "quiz-id": quizId
    }, function(data) {
        if (typeof(data) == "object") {
            finishExam(data.state);
            $("#displayed-question-id").attr("value", data.displayed_question);
            $("#online-quiz-question-area").html(data.html);
            var result = document.getElementById("online-quiz-question-area");
            MathJax.Hub.Queue(["Typeset", MathJax.Hub, result]);
        } else if (typeof(data) == "string") {
            $("#online-quiz-question-area").html(data);
            $("#online-quiz-buttons").hide();
        }
    }, "json");
}

function disableAllButtons() 
{
    $("#skip").attr("disabled", "disabled");
    $("#next").attr("disabled", "disabled");
    $("#previous").attr("disabled", "disabled");
}

function finishExam(state) {
    var maxQuestionNumber = $("#number-of-questions").val();
    var minQuestionNumber = 1;
    state = parseInt(state);
    if (state == 1) 
    {
        $("#skip-question").attr("disabled", "disabled");
        $("#next-question").css("display", "none");
        $("#prev-question").css("display", "inline");
        $("#prev-question").removeAttr("disabled");
        $("#finish-quiz").css("display", "inline");
        $("#finish-quiz").removeAttr("disabled");
    } else if (state == 0) {
        $("#prev-question").css("display", "none");
        $("#next-question").css("display", "inline");
        $("#next-question").removeAttr("disabled");
        $("#skip-question").removeAttr("disabled");
        $("#finish-quiz").css("display", "none");
    } else if (state == -1) {
        $("#prev-question").css("display", "inline");
        $("#prev-question").removeAttr("disabled");
        $("#next-question").css("display", "inline");
        $("#next-question").removeAttr("disabled");
        $("#skip-question").removeAttr("disabled");
        $("#finish-quiz").css("display", "none");
    }
}

function getAnswers() {
    var array = Array();
    var radio = $("input:radio[name='radio_values']:checked").val();
    if (radio != undefined) {
        array[0] = $("input:radio[name='radio_values']:checked").val();
    }
    else {
        return array;
    }
    return array;
}

function printError() {
    $("#online-quiz-question-error-messages").html("<div style='padding:5px 0 5px 50px;border:1px solid red'>Select answer.</div>");
    $("#previous").removeAttr("disabled");
    $("#next").removeAttr("disabled");
    $("#skip").removeAttr("disabled");
}
